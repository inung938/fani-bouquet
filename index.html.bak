<!DOCTYPE html>

<html class="scroll-smooth" lang="en">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Petals &amp; Poise | Curating Nature's Finest Moments</title>
    <!-- Google Fonts: EB Garamond for Serif, Plus Jakarta Sans for Sans -->
    <link
        href="https://fonts.googleapis.com/css2?family=EB+Garamond:wght@400;500;600;700&amp;family=Plus+Jakarta+Sans:wght@400;500;600;700&amp;display=swap"
        rel="stylesheet" />
    <!-- Material Symbols Outlined -->
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
        rel="stylesheet" />
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
        rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "on-primary-fixed": "#2c1600",
                        "tertiary": "#745662",
                        "on-error-container": "#93000a",
                        "surface-container": "#edefe7",
                        "surface-container-high": "#e8e9e1",
                        "surface-variant": "#e2e3db",
                        "surface-dim": "#d9dbd3",
                        "on-primary": "#ffffff",
                        "on-error": "#ffffff",
                        "inverse-on-surface": "#f0f1e9",
                        "secondary-fixed": "#e1e6c2",
                        "secondary": "#5c6145",
                        "on-background": "#1a1c18",
                        "on-secondary-fixed": "#1a1d07",
                        "on-primary-container": "#5b3912",
                        "inverse-surface": "#2f312c",
                        "secondary-fixed-dim": "#c5c9a7",
                        "surface-tint": "#7d562d",
                        "on-surface-variant": "#50453b",
                        "background": "#f9faf2",
                        "on-primary-fixed-variant": "#623f18",
                        "tertiary-fixed": "#ffd8e7",
                        "on-tertiary": "#ffffff",
                        "outline": "#82756a",
                        "surface-container-highest": "#e2e3db",
                        "on-secondary-fixed-variant": "#45492f",
                        "outline-variant": "#d4c4b7",
                        "primary-fixed-dim": "#f0bd8b",
                        "inverse-primary": "#f0bd8b",
                        "primary-container": "#d4a373",
                        "tertiary-fixed-dim": "#e3bccb",
                        "surface": "#f9faf2",
                        "error": "#ba1a1a",
                        "error-container": "#ffdad6",
                        "surface-container-lowest": "#ffffff",
                        "on-tertiary-fixed": "#2b141f",
                        "secondary-container": "#e1e6c2",
                        "on-tertiary-fixed-variant": "#5b3f4b",
                        "on-secondary": "#ffffff",
                        "surface-bright": "#f9faf2",
                        "tertiary-container": "#c8a3b1",
                        "on-secondary-container": "#62674a",
                        "surface-container-low": "#f3f4ec",
                        "on-tertiary-container": "#543944",
                        "primary-fixed": "#ffdcbd",
                        "primary": "#7d562d",
                        "on-surface": "#1a1c18"
                    },
                    "borderRadius": {
                        "DEFAULT": "0.25rem",
                        "lg": "0.5rem",
                        "xl": "0.75rem",
                        "full": "9999px"
                    },
                    "spacing": {
                        "gutter": "24px",
                        "base": "8px",
                        "container-max": "1280px",
                        "margin-mobile": "16px",
                        "margin-desktop": "64px"
                    },
                    "fontFamily": {
                        "label-sm": ["Plus Jakarta Sans"],
                        "display-lg": ["EB Garamond"],
                        "display-lg-mobile": ["EB Garamond"],
                        "headline-sm": ["EB Garamond"],
                        "body-lg": ["Plus Jakarta Sans"],
                        "headline-md": ["EB Garamond"],
                        "body-md": ["Plus Jakarta Sans"],
                        "label-md": ["Plus Jakarta Sans"]
                    },
                    "fontSize": {
                        "label-sm": ["12px", { "lineHeight": "16px", "fontWeight": "700" }],
                        "display-lg": ["48px", { "lineHeight": "56px", "letterSpacing": "-0.02em", "fontWeight": "500" }],
                        "display-lg-mobile": ["36px", { "lineHeight": "42px", "fontWeight": "500" }],
                        "headline-sm": ["24px", { "lineHeight": "32px", "fontWeight": "600" }],
                        "body-lg": ["18px", { "lineHeight": "28px", "fontWeight": "400" }],
                        "headline-md": ["32px", { "lineHeight": "40px", "fontWeight": "500" }],
                        "body-md": ["16px", { "lineHeight": "24px", "fontWeight": "400" }],
                        "label-md": ["14px", { "lineHeight": "20px", "letterSpacing": "0.05em", "fontWeight": "600" }]
                    }
                },
            },
        }
    </script>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
            display: inline-block;
            vertical-align: middle;
        }

        .glass-effect {
            backdrop-filter: blur(12px);
            background-color: rgba(255, 255, 255, 0.15);
            border: 1px solid rgba(255, 255, 255, 0.2);
        }

        .hero-gradient {
            background: linear-gradient(to bottom, rgba(26, 28, 24, 0.2), rgba(26, 28, 24, 0.6));
        }
    </style>
</head>

<body class="bg-background text-on-surface selection:bg-primary-container selection:text-on-primary-container">
    <!-- Top Navigation Bar -->
    <header class="w-full top-0 sticky z-50 bg-background/80 dark:bg-background/80 backdrop-blur-md">
        <nav
            class="flex justify-between items-center w-full px-margin-mobile md:px-margin-desktop py-4 max-w-container-max mx-auto">
            <div class="font-display-lg text-display-lg-mobile md:text-display-lg text-primary">
                Petals &amp; Poise
            </div>
            <!-- Desktop Links -->
            <div class="hidden md:flex gap-8 items-center">
                <a class="font-body-md text-body-md text-on-surface-variant hover:text-primary transition-colors"
                    href="#">Gallery</a>
                <a class="font-body-md text-body-md text-on-surface-variant hover:text-primary transition-colors"
                    href="#">Story</a>
                <a class="font-body-md text-body-md text-primary font-bold border-b-2 border-primary pb-1"
                    href="#">Catalog</a>
                <a class="font-body-md text-body-md text-on-surface-variant hover:text-primary transition-colors"
                    href="#">Reviews</a>
            </div>
            <button
                class="bg-primary text-on-primary font-label-md text-label-md px-6 py-3 rounded-full hover:bg-primary/90 hover:scale-95 transition-all shadow-sm">
                Shop Now
            </button>
        </nav>
    </header>
    <main>
        <!-- Hero Section -->
        <section class="relative min-h-[85vh] flex items-center justify-center overflow-hidden">
            <!-- Background Image -->
            <div class="absolute inset-0 z-0">
                <div class="absolute inset-0 hero-gradient z-10"></div>
                <img alt="Petals &amp; Poise Floral Shop" class="w-full h-full object-cover"
                    src="https://lh3.googleusercontent.com/aida-public/AB6AXuCsub9dD1gtWlcs-Sdsbpehj8VI-k2-IBrAYiAZYBUCJBrDBatunRVp9L-yxu_qgt5xi8E-Nj9IeZ_UnKVpdyzDeOcwCWi0OlJdM1UAmmSj6qQf0I7VvEDQjV35rzNIidjzckORz5wWWAy506C3uqF_aO_cPTG4ax4CcL-ZM1msEV0D9-oodwVD4QCncjVbzVwbyM3g78yywP3xhvzfgxN9XUC6Ui-3B0LzEBbYlr-i_ags6KMzh00HUlMYNl1bOqnsJLi6RT4tlec" />
            </div>
            <!-- Content -->
            <div class="relative z-20 text-center px-margin-mobile max-w-4xl mx-auto flex flex-col items-center">
                <h1 class="font-display-lg text-[44px] md:text-[80px] leading-tight text-white drop-shadow-lg mb-4">
                    Petals &amp; Poise
                </h1>
                <p class="font-headline-md text-white/90 italic mb-6">
                    Sentuhan Keindahan dalam Setiap Ikatan
                </p>
                <p class="font-body-lg text-white/80 max-w-2xl mx-auto mb-10 leading-relaxed">
                    Kami mengkurasi momen-momen terbaik alam ke dalam buket bunga yang elegan untuk setiap perayaan
                    spesial Anda.
                </p>
                <a class="inline-flex items-center gap-2 bg-white text-primary font-label-md text-label-md px-10 py-5 rounded-full hover:bg-secondary-container transition-all hover:scale-105 shadow-xl group"
                    href="#catalog">
                    Lihat Katalog
                    <span
                        class="material-symbols-outlined group-hover:translate-x-1 transition-transform">arrow_forward</span>
                </a>
            </div>
        </section>
        <!-- Aesthetic Stats/Features Section (Asymmetric) -->
        <section class="py-24 px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto overflow-hidden">
            <div class="grid grid-cols-1 md:grid-cols-12 gap-gutter items-center">
                <div class="md:col-span-5 relative">
                    <div class="aspect-[4/5] rounded-[40px] overflow-hidden shadow-2xl relative">
                        <img class="w-full h-full object-cover"
                            data-alt="A beautiful closeup of a premium bouquet with soft pink peonies, white ranunculus, and delicate eucalyptus leaves, captured in natural morning light against a soft cream background, minimalist high-end luxury aesthetic."
                            src="https://lh3.googleusercontent.com/aida-public/AB6AXuCDY9nLZ3_ktWMGTS-hnC-0NQ5D7f1hjTJOXfiasVuUwaInStzhB4uZbKekEoG-LPXzWkys9d7tmDGTljKUis1odesaZN2qwXWKzephaQLfW-jyBK6tMJsQWV-YmqDWMz4ag-lHqz6-xlrW5kwqmmY-impG47rd6jwGllNdQl9mxdftTnllO6snCH1cBAFGM-wmLcmixsvyT2FM2PQMgINjL1iz8hbc0ZS34XBVaDRGAv6hxm7hBsn3cGu9pR8mu6rZxFkKcJ46ZDQ" />
                    </div>
                    <!-- Overlapping Decorative Element -->
                    <div
                        class="absolute -bottom-8 -right-8 w-48 h-48 bg-tertiary-container rounded-full mix-blend-multiply opacity-30 blur-3xl">
                    </div>
                </div>
                <div class="md:col-span-7 md:pl-16 space-y-8 mt-12 md:mt-0">
                    <span class="font-label-md text-label-md uppercase tracking-[0.2em] text-primary">Filosofi
                        Kami</span>
                    <h2 class="font-headline-md text-[40px] leading-tight text-on-surface">Kualitas yang Berakar pada
                        Kesempurnaan Alam</h2>
                    <p class="font-body-lg text-on-surface-variant">Setiap tangkai dipilih secara manual oleh perangkai
                        bunga ahli kami, memastikan hanya mahkota bunga paling segar yang masuk ke dalam koleksi Anda.
                    </p>
                    <div class="grid grid-cols-2 gap-8 pt-6">
                        <div class="space-y-2">
                            <h4 class="font-display-lg text-4xl text-primary">100+</h4>
                            <p class="font-label-sm text-on-surface-variant">Varian Bunga Eksotis</p>
                        </div>
                        <div class="space-y-2">
                            <h4 class="font-display-lg text-4xl text-primary">15k</h4>
                            <p class="font-label-sm text-on-surface-variant">Momen Berbahagia</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>
        <!-- Social Media Section -->
        <section class="py-24 bg-surface-container-low">
            <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop text-center">
                <span class="font-label-md text-label-md text-tertiary uppercase tracking-widest mb-4 block mb-6">Let's
                    Connect</span>
                <h2 class="font-headline-md text-on-surface mb-12">Temukan Kami di Media Sosial</h2>
                <div class="flex flex-wrap justify-center gap-6 md:gap-12">
                    <!-- Instagram -->
                    <a class="group flex flex-col items-center gap-4 transition-all hover:-translate-y-2" href="#">
                        <div
                            class="w-20 h-20 rounded-full bg-white flex items-center justify-center shadow-lg group-hover:bg-primary group-hover:text-white transition-colors duration-500">
                            <span class="material-symbols-outlined text-3xl">photo_camera</span>
                        </div>
                        <span
                            class="font-label-md text-label-md text-on-surface-variant group-hover:text-primary">Instagram<br /><span
                                class="text-label-sm opacity-70">@petalsandpoise</span></span>
                    </a>
                    <!-- TikTok -->
                    <a class="group flex flex-col items-center gap-4 transition-all hover:-translate-y-2" href="#">
                        <div
                            class="w-20 h-20 rounded-full bg-white flex items-center justify-center shadow-lg group-hover:bg-primary group-hover:text-white transition-colors duration-500">
                            <span class="material-symbols-outlined text-3xl">movie_edit</span>
                        </div>
                        <span
                            class="font-label-md text-label-md text-on-surface-variant group-hover:text-primary">TikTok<br /><span
                                class="text-label-sm opacity-70">@petals.poise</span></span>
                    </a>
                    <!-- WhatsApp -->
                    <a class="group flex flex-col items-center gap-4 transition-all hover:-translate-y-2" href="#">
                        <div
                            class="w-20 h-20 rounded-full bg-white flex items-center justify-center shadow-lg group-hover:bg-primary group-hover:text-white transition-colors duration-500">
                            <span class="material-symbols-outlined text-3xl">chat_bubble</span>
                        </div>
                        <span
                            class="font-label-md text-label-md text-on-surface-variant group-hover:text-primary">WhatsApp<br /><span
                                class="text-label-sm opacity-70">Chat with us</span></span>
                    </a>
                </div>
                <!-- Live Feed Suggestion (Bento Grid) -->
                <div class="mt-20 grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
                    <div class="aspect-square rounded-2xl overflow-hidden shadow-sm group">
                        <img class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                            data-alt="A lifestyle photo of a customer holding a large, elegant bouquet wrapped in premium brown paper and tied with a silk ribbon. Background is a sun-drenched flower shop window, warm tones, high luxury vibe."
                            src="https://lh3.googleusercontent.com/aida-public/AB6AXuBknvHy_Czq04bxJJVRouvujdDUIsM7PET4y3iOqeGHv351-EHqIvVW6Wl97WwlqWE3Hjqp2KE2okxAFY5JRBdythPGYlfN2FJpwhzaiuFLSLwRURdKeqWBSMJvU8_GsbMdkrkdsC7S7nYoUiDi9KubpmTZcyHywnylQWU91MinzMXA5f3J4ThGEE4ixcCNFdqa-RKsPlHC_fqSS9F0hBhQT6Jk8eVN_p29yiMMPKtI0f43z7TTNPXZhl-1y19dBu3Pa30h2VD9l0o" />
                    </div>
                    <div class="aspect-square rounded-2xl overflow-hidden shadow-sm group md:mt-8">
                        <img class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                            data-alt="Macro shot of morning dew on the petals of a deep red rose. Extremely high detail, soft focus background, lighting captures the glisten of water droplets, part of a florist's garden scene."
                            src="https://lh3.googleusercontent.com/aida-public/AB6AXuBpHyhWk-x1S19heVRk2tS-fjvXlHA_T0iYr62fmKvcwMSTvWQrvyaA6Ldtjhx_nU6DhtYLNl6qN2om02jC84ommQc5ETG19GPspxeagSUxIRXM0wrDxFmkK1SDaGTY6y6p0Ka8Yx1JEMp8SXoxPbzOHdgCBIHDxCwD8wszdIh_fPC3nETrf5OA7PNYbz_VSQeea8dKnGOPnhqMYPoYJzXstSs7Q9ZkpfF5Z7i1HEf-Ioijj-VJ6E_G8peJFF3ZcmIQExGpnLXHlJA" />
                    </div>
                    <div class="aspect-square rounded-2xl overflow-hidden shadow-sm group">
                        <img class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                            data-alt="Modern minimalist floral arrangement in a glass vase on a marble table. Single white orchid stem with green foliage, bright airy setting, contemporary interior design aesthetic."
                            src="https://lh3.googleusercontent.com/aida-public/AB6AXuBugxjmXI3crQZIueQMGnjJ_Xt2KKmVtbdlbjwab2o-Vx2qPUu6miZ8Lk0uVoDgMg2EfE_Cc2CklRCPhx7r5y83592WwMUzvI4MHSDZu3LOyEE5B2h3S5yVTXPBlQmT-kETCX41uLb-kScyRXL__tW5T5-QwuDqr-y5SbjNykT7deSkI0QwLuWypVTdtt-KfDmUi15hP7NRJ4QFAuBgTuS-oNLTchUlafkbamwN-iqZ8bJW3PdGKLZX60q0_d3s_nJexhIftwirMns" />
                    </div>
                    <div class="aspect-square rounded-2xl overflow-hidden shadow-sm group md:mt-8">
                        <img class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                            data-alt="A florist's hands carefully arranging a variety of wild flowers including lavender, chamomile, and baby's breath. Soft natural light from a window, rustic and elegant feel."
                            src="https://lh3.googleusercontent.com/aida-public/AB6AXuCGnem3MMYFvrascDlmoSMBRJyA8yWykMCMDxPtsHBqHtkFzUOfNDlemcTNTAey_ThboA9cDartwPDKLBnTZd0CIlyswVqNg9P7_SFzf4jF5QFPKa8CQqZBIz6wg-Q_r4ui6UEM_eXq4B32q0LRyzWmRymfHC5dJ5Cq9Wn-N0ftk_WrkyZBgDwajwe7kkZ6bnUtIg1t4D0PlMOAfnfMPuJxPT0ASbI3xgOLv1XwYj-bAgGtm3gNBzP-cvui09CD-52iDbTkA_CsKJE" />
                    </div>
                </div>
            </div>
        </section>
        <!-- Newsletter / CTA Section -->
        <section class="py-24 px-margin-mobile">
            <div
                class="max-w-4xl mx-auto rounded-[48px] bg-primary-container p-12 md:p-20 text-center relative overflow-hidden">
                <!-- Background texture/pattern simulation -->
                <div class="absolute inset-0 opacity-10 pointer-events-none"
                    style="background-image: radial-gradient(circle at 2px 2px, #fff 1px, transparent 0); background-size: 24px 24px;">
                </div>
                <h3 class="font-headline-md text-on-primary-container mb-6 relative z-10">Dapatkan Inspirasi Setiap
                    Pekan</h3>
                <p class="font-body-md text-on-primary-container/80 mb-10 relative z-10 max-w-md mx-auto">Daftarkan
                    email Anda untuk mendapatkan tips perawatan bunga dan penawaran eksklusif setiap bulannya.</p>
                <form class="flex flex-col md:flex-row gap-4 max-w-lg mx-auto relative z-10">
                    <input
                        class="flex-grow px-6 py-4 rounded-full border-none bg-white focus:ring-2 focus:ring-primary shadow-inner font-body-md"
                        placeholder="Email Anda" type="email" />
                    <button
                        class="bg-primary text-on-primary px-10 py-4 rounded-full font-label-md text-label-md hover:bg-on-primary-fixed transition-colors"
                        type="submit">Daftar</button>
                </form>
            </div>
        </section>
    </main>
    <!-- Footer -->
    <footer class="w-full mt-auto bg-surface-container-low dark:bg-surface-container-lowest">
        <div
            class="flex flex-col md:flex-row justify-between items-center w-full px-margin-mobile md:px-margin-desktop py-12 gap-8 max-w-container-max mx-auto">
            <div class="flex flex-col items-center md:items-start gap-4">
                <div class="font-headline-sm text-headline-sm text-primary">Petals &amp; Poise</div>
                <p class="font-label-md text-label-md text-on-secondary-container max-w-xs text-center md:text-left">
                    © 2024 Petals &amp; Poise. Curating nature's finest moments.
                </p>
            </div>
            <div class="flex flex-wrap justify-center md:justify-end gap-x-8 gap-y-4">
                <a class="font-label-md text-label-md text-on-secondary-container hover:text-primary transition-colors underline-offset-4 hover:underline"
                    href="#">Instagram</a>
                <a class="font-label-md text-label-md text-on-secondary-container hover:text-primary transition-colors underline-offset-4 hover:underline"
                    href="#">TikTok</a>
                <a class="font-label-md text-label-md text-on-secondary-container hover:text-primary transition-colors underline-offset-4 hover:underline"
                    href="#">WhatsApp</a>
                <a class="font-label-md text-label-md text-on-secondary-container hover:text-primary transition-colors underline-offset-4 hover:underline"
                    href="#">Privacy Policy</a>
                <a class="font-label-md text-label-md text-on-secondary-container hover:text-primary transition-colors underline-offset-4 hover:underline"
                    href="#">Shipping</a>
            </div>
        </div>
    </footer>
    <!-- Simple Hover Interactivity -->
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const buttons = document.querySelectorAll('button, a');
            buttons.forEach(btn => {
                btn.addEventListener('mousedown', () => {
                    btn.classList.add('scale-95');
                });
                btn.addEventListener('mouseup', () => {
                    btn.classList.remove('scale-95');
                });
                btn.addEventListener('mouseleave', () => {
                    btn.classList.remove('scale-95');
                });
            });
        });
    </script>
</body>

</html>